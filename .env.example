# ─── Anthropic (engine) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Clerk (magic-link auth + dashboard) ───────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Upstash Redis (user/credit/rewrite state) ─────────────────────────
# Vercel Marketplace integration auto-provisions these.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Stripe (credit-pack purchases) ────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# 12 price IDs: 2 packs × 6 currencies. Create in Stripe dashboard:
#   3-pack: GBP £9.99 / USD $9.99 / EUR €9.99 / AUD A$15 / CAD C$13 / NZD NZ$16
#   10-pack: GBP £19.99 / USD $19.99 / EUR €19.99 / AUD A$30 / CAD C$26 / NZD NZ$32
STRIPE_PRICE_GBP_PACK3=
STRIPE_PRICE_GBP_PACK10=
STRIPE_PRICE_USD_PACK3=
STRIPE_PRICE_USD_PACK10=
STRIPE_PRICE_EUR_PACK3=
STRIPE_PRICE_EUR_PACK10=
STRIPE_PRICE_AUD_PACK3=
STRIPE_PRICE_AUD_PACK10=
STRIPE_PRICE_CAD_PACK3=
STRIPE_PRICE_CAD_PACK10=
STRIPE_PRICE_NZD_PACK3=
STRIPE_PRICE_NZD_PACK10=

# ─── Resend (post-rewrite email with PDF) ──────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL="ATS Rewriter <hello@example.com>"

# ─── Creator-programme attribution (Almost Legal portfolio shared) ─────
# Lives in almostlegal-ai production env. Pull via:
#   vercel env pull /tmp/al.env --environment=production --yes (in almostlegal-ai)
CREATOR_TRACK_SECRET=
CREATOR_TRACK_URL=https://almostlegal.ai/api/track/sale
CREATOR_CLICK_URL=https://almostlegal.ai/api/track-click

# ─── App URLs ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BRAND_DOMAIN=ats-rewriter.com

# ─── Analytics (optional) ──────────────────────────────────────────────
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_ID=
